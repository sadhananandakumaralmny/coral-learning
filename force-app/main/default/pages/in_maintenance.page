<apex:page showHeader="false" sidebar="false" standardStylesheets="false" applyHtmlTag="false" applyBodyTag="false" docType="html-5">
    <html xmlns="http://www.w3.org/2000/xhtml" lang="en">
        <head>
            <meta charset="utf-8"/>
            <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
            <meta name="viewport" content="width=device-width, initial-scale=1"/>
            <title>Coral Learning - Under Maintenance</title>
            
            <!-- Salesforce Lightning Design System -->
            <apex:slds />
            
            <!-- Custom CSS -->
            <style>
                body {
                    font-family: 'Salesforce Sans', Arial, sans-serif;
                    margin: 0;
                    padding: 0;
                    background: #f8f9fa;
                    min-height: 100vh;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }
                
                .maintenance-container {
                    background: white;
                    border-radius: 12px;
                    padding: 3rem;
                    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
                    width: 100%;
                    max-width: 500px;
                    text-align: center;
                }
                
                .maintenance-icon {
                    font-size: 4rem;
                    margin-bottom: 1rem;
                    opacity: 0.7;
                }
                
                .maintenance-title {
                    color: #ffc107;
                    font-size: 1.5rem;
                    font-weight: 600;
                    margin-bottom: 1rem;
                }
                
                .maintenance-message {
                    color: #706e6b;
                    margin-bottom: 2rem;
                    font-size: 1.1rem;
                    line-height: 1.5;
                }
                
                .estimated-time {
                    background: #fff3cd;
                    border: 1px solid #ffeaa7;
                    border-radius: 6px;
                    padding: 1rem;
                    margin-bottom: 2rem;
                    color: #856404;
                }
                
                .refresh-button {
                    display: inline-block;
                    padding: 0.75rem 1.5rem;
                    background: #1589ee;
                    color: white;
                    text-decoration: none;
                    border-radius: 6px;
                    font-weight: 600;
                    transition: background-color 0.2s ease;
                }
                
                .refresh-button:hover {
                    background: #0d6efd;
                    text-decoration: none;
                    color: white;
                }
                
                .help-text {
                    margin-top: 2rem;
                    color: #706e6b;
                    font-size: 0.9rem;
                }
                
                .help-text a {
                    color: #1589ee;
                    text-decoration: none;
                }
                
                .help-text a:hover {
                    text-decoration: underline;
                }
                
                @media (max-width: 480px) {
                    .maintenance-container {
                        margin: 1rem;
                        padding: 2rem;
                    }
                }
            </style>
        </head>
        <body>
            <div class="maintenance-container">
                <div class="maintenance-icon">
                    🔧
                </div>
                
                <h1 class="maintenance-title">
                    Under Maintenance
                </h1>
                
                <p class="maintenance-message">
                    We're currently performing scheduled maintenance to improve your experience. 
                    Please check back soon.
                </p>
                
                <div class="estimated-time">
                    <strong>Estimated completion:</strong> 2 hours
                </div>
                
                <a href="javascript:location.reload()" class="refresh-button">
                    Refresh Page
                </a>
                
                <div class="help-text">
                    Need help? <a href="#">Contact Support</a>
                </div>
            </div>
        </body>
    </html>
</apex:page>
