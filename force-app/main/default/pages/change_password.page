<apex:page showHeader="false" sidebar="false" standardStylesheets="false" applyHtmlTag="false" applyBodyTag="false" docType="html-5">
    <html xmlns="http://www.w3.org/2000/xhtml" lang="en">
        <head>
            <meta charset="utf-8"/>
            <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
            <meta name="viewport" content="width=device-width, initial-scale=1"/>
            <title>Coral Learning - Change Password</title>
            
            <!-- Salesforce Lightning Design System -->
            <apex:slds />
            
            <!-- Custom CSS -->
            <style>
                body {
                    font-family: 'Salesforce Sans', Arial, sans-serif;
                    margin: 0;
                    padding: 0;
                    background: #f8f9fa;
                    min-height: 100vh;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }
                
                .password-container {
                    background: white;
                    border-radius: 12px;
                    padding: 3rem;
                    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
                    width: 100%;
                    max-width: 400px;
                    text-align: center;
                }
                
                .logo {
                    font-size: 1.5rem;
                    font-weight: bold;
                    color: #1589ee;
                    margin-bottom: 1rem;
                }
                
                .title {
                    color: #16325c;
                    font-size: 1.5rem;
                    font-weight: 600;
                    margin-bottom: 1rem;
                }
                
                .subtitle {
                    color: #706e6b;
                    margin-bottom: 2rem;
                    font-size: 1rem;
                }
                
                .form-group {
                    margin-bottom: 1.5rem;
                    text-align: left;
                }
                
                .form-label {
                    display: block;
                    margin-bottom: 0.5rem;
                    color: #16325c;
                    font-weight: 500;
                }
                
                .form-input {
                    width: 100%;
                    padding: 0.75rem;
                    border: 2px solid #e5e5e5;
                    border-radius: 6px;
                    font-size: 1rem;
                    transition: border-color 0.2s ease;
                    box-sizing: border-box;
                }
                
                .form-input:focus {
                    outline: none;
                    border-color: #1589ee;
                }
                
                .submit-button {
                    width: 100%;
                    padding: 0.75rem;
                    background: #1589ee;
                    color: white;
                    border: none;
                    border-radius: 6px;
                    font-size: 1rem;
                    font-weight: 600;
                    cursor: pointer;
                    transition: background-color 0.2s ease;
                }
                
                .submit-button:hover {
                    background: #0d6efd;
                }
                
                .back-link {
                    margin-top: 1.5rem;
                    color: #706e6b;
                    font-size: 0.9rem;
                }
                
                .back-link a {
                    color: #1589ee;
                    text-decoration: none;
                }
                
                .back-link a:hover {
                    text-decoration: underline;
                }
                
                @media (max-width: 480px) {
                    .password-container {
                        margin: 1rem;
                        padding: 2rem;
                    }
                }
            </style>
        </head>
        <body>
            <div class="password-container">
                <div class="logo">
                    🐠 Coral Learning
                </div>
                
                <h1 class="title">
                    Change Password
                </h1>
                
                <p class="subtitle">
                    Enter your new password below
                </p>
                
                <apex:form>
                    <div class="form-group">
                        <label class="form-label" for="newPassword">New Password</label>
                        <input type="password" id="newPassword" name="newPassword" class="form-input" required="true" />
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label" for="confirmPassword">Confirm New Password</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" class="form-input" required="true" />
                    </div>
                    
                    <apex:commandButton value="Update Password" action="{!changePassword}" styleClass="submit-button" />
                </apex:form>
                
                <div class="back-link">
                    <a href="/apex/student_dashboard">← Back to Dashboard</a>
                </div>
            </div>
        </body>
    </html>
</apex:page>
