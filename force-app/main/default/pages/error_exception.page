<apex:page showHeader="false" sidebar="false" standardStylesheets="false" applyHtmlTag="false" applyBodyTag="false" docType="html-5">
    <html xmlns="http://www.w3.org/2000/xhtml" lang="en">
        <head>
            <meta charset="utf-8"/>
            <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
            <meta name="viewport" content="width=device-width, initial-scale=1"/>
            <title>Coral Learning - Error</title>
            
            <!-- Salesforce Lightning Design System -->
            <apex:slds />
            
            <!-- Custom CSS -->
            <style>
                body {
                    font-family: 'Salesforce Sans', Arial, sans-serif;
                    margin: 0;
                    padding: 0;
                    background: #f8f9fa;
                    min-height: 100vh;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }
                
                .error-container {
                    background: white;
                    border-radius: 12px;
                    padding: 3rem;
                    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
                    width: 100%;
                    max-width: 500px;
                    text-align: center;
                }
                
                .error-icon {
                    font-size: 4rem;
                    margin-bottom: 1rem;
                    opacity: 0.7;
                }
                
                .error-title {
                    color: #dc3545;
                    font-size: 1.5rem;
                    font-weight: 600;
                    margin-bottom: 1rem;
                }
                
                .error-message {
                    color: #706e6b;
                    margin-bottom: 2rem;
                    font-size: 1.1rem;
                    line-height: 1.5;
                }
                
                .back-button {
                    display: inline-block;
                    padding: 0.75rem 1.5rem;
                    background: #1589ee;
                    color: white;
                    text-decoration: none;
                    border-radius: 6px;
                    font-weight: 600;
                    transition: background-color 0.2s ease;
                }
                
                .back-button:hover {
                    background: #0d6efd;
                    text-decoration: none;
                    color: white;
                }
                
                .help-text {
                    margin-top: 2rem;
                    color: #706e6b;
                    font-size: 0.9rem;
                }
                
                .help-text a {
                    color: #1589ee;
                    text-decoration: none;
                }
                
                .help-text a:hover {
                    text-decoration: underline;
                }
                
                @media (max-width: 480px) {
                    .error-container {
                        margin: 1rem;
                        padding: 2rem;
                    }
                }
            </style>
        </head>
        <body>
            <div class="error-container">
                <div class="error-icon">
                    ⚠️
                </div>
                
                <h1 class="error-title">
                    Something went wrong
                </h1>
                
                <p class="error-message">
                    We encountered an unexpected error while processing your request. 
                    Please try again or contact support if the problem persists.
                </p>
                
                <a href="/apex/student_dashboard" class="back-button">
                    Back to Dashboard
                </a>
                
                <div class="help-text">
                    Need help? <a href="#">Contact Support</a>
                </div>
            </div>
        </body>
    </html>
</apex:page>
